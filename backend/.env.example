# OpenRouter — powers LLMs via free-tier models
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Groq — fast inference on Llama/Gemma models (free tier)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# GitHub Models — free OpenAI-compatible models (gpt-4o-mini, Llama, Mistral, Phi)
# Create a classic PAT at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here

# Serper — used by SerperDevTool for web search
# Get your key at: https://serper.dev
SERPER_API_KEY=your_serper_key_here

# PostgreSQL — only needed if you use PGSearchTool
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=
